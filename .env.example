# Public app
NEXT_PUBLIC_APP_URL=https://your-domain.example
NEXT_PUBLIC_DEFAULT_BUSINESS_SLUG=bon-plus-cafe

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Google Business Profile reviews sync
# Prefer refresh-token flow. ACCESS_TOKEN is optional as a temporary fallback.
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_BUSINESS_REFRESH_TOKEN=
GOOGLE_BUSINESS_ACCESS_TOKEN=

# Integration route secrets
INTEGRATIONS_CRON_SECRET=replace-with-a-long-random-secret
TALABAT_REVIEWS_WEBHOOK_SECRET=replace-with-a-long-random-secret
